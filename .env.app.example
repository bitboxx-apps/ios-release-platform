# .env.app — Application-specific values
# Copy to .env.app and fill in values

# App name (used for Xcode project, target, scheme, and Swift struct names)
# Must start with a letter. Only letters, digits, and underscores allowed.
# Example: MyApp, PostalCode, Weather_App
APP_NAME=

# App display name (shown on the iOS home screen)
# Can contain spaces, Japanese characters, emoji, etc.
# Example: My App, 郵便番号検索, Weather App
APP_DISPLAY_NAME=

# App bundle identifier (reverse-DNS format)
# Example: com.company.myapp, jp.co.example.apps.myapp
APP_BUNDLE_ID=

# Match type: appstore, adhoc, development
MATCH_TYPE=appstore

# App Store Connect API Key ID (for TestFlight / App Store upload)
ASC_KEY_ID=

# App Store Connect Issuer ID (UUID)
ASC_ISSUER_ID=

# Local path to App Store Connect API key (.p8)
# Used by setup-secrets.sh to base64-encode and upload to GitHub Secrets
ASC_KEY_PATH=

# Local path to SSH private key for match signing repo access
# Used by setup-secrets.sh to upload to GitHub Secrets
MATCH_GIT_PRIVATE_KEY_PATH=
