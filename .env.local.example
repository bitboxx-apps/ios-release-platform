# .env.local — Developer overrides (git-ignored)
# Copy to .env.local for local development
# Precedence: .env.local > .env.app > .env.platform

# Override any value from .env.platform or .env.app here
# Example:
# MATCH_TYPE=development

# Optional: Apple ID email used by fastlane/match when talking to the Apple Developer Portal.
# Useful if you belong to multiple teams or want to avoid interactive prompts.
#
# APPLE_ID=your.name@example.com
#
# Do NOT store Apple ID passwords in env files.
# fastlane will prompt as needed and can store credentials in the macOS Keychain.
