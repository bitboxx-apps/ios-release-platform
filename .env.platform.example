# .env.platform — Organization-level constants
# Copy to .env.platform and fill in values

# Apple Developer Team ID (10-character alphanumeric)
APPLE_TEAM_ID=

# Git URL for match signing repository (SSH recommended)
# Example: git@github.com:your-org/ios-signing.git
MATCH_GIT_URL=

# Match encryption password
MATCH_PASSWORD=

# Match storage mode (git or s3)
MATCH_STORAGE_MODE=git
